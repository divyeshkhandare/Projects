# ─────────────────────────────────────────────────────────────────────────────
# CodeForge — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=codeforge
DB_PASSWORD=codeforge_secret
DB_NAME=codeforge
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://codeforge:codeforge_secret@localhost:5432/codeforge

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── OpenAI (AI Features) ─────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_TYPE=local          # Options: local | s3
UPLOADS_DIR=./uploads

# S3 (if STORAGE_TYPE=s3)
AWS_BUCKET_NAME=codeforge-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ─── Docker Sandbox ───────────────────────────────────────────────────────────
SANDBOX_TIMEOUT=15          # seconds
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_NETWORK=none        # Isolate containers from network

# ─── Email (for password reset) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@codeforge.dev

# ─── Frontend Vite ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100
EXECUTE_RATE_LIMIT_MAX=20     # code runs per window
