// ============================================
// Environment Configuration
// ============================================

# Binance API (optional for authenticated endpoints)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# OpenAI API Key (for AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# MongoDB (optional - uses in-memory store if not set)
